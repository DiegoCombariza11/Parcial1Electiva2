<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar sesión — UPTC Sogamoso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --uptc-gold: #F5A800;
            --uptc-dark: #1a1a1a;
        }
        body {
            background-color: #f9f5e8;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .navbar-uptc { background-color: var(--uptc-dark); }
        .navbar-brand { color: var(--uptc-gold) !important; }
        .card-header-uptc {
            background-color: var(--uptc-gold);
            color: var(--uptc-dark);
            font-weight: 600;
        }
        .card-header-dark {
            background-color: var(--uptc-dark);
            color: var(--uptc-gold);
            font-weight: 600;
        }
        .btn-uptc {
            background-color: var(--uptc-gold);
            color: var(--uptc-dark);
            font-weight: 600;
            border: none;
        }
        .btn-uptc:hover { background-color: #d4900a; color: #fff; }
        .btn-dark-uptc {
            background-color: var(--uptc-dark);
            color: var(--uptc-gold);
            border: none;
        }
        .btn-dark-uptc:hover { background-color: #333; color: var(--uptc-gold); }
        main { flex: 1; }
    </style>
</head>
<body>

<nav class="navbar navbar-uptc mb-4">
    <div class="container-fluid">
        <div class="d-flex w-100 justify-content-between align-items-center">
            <a class="navbar-brand fw-bold" href="/">UPTC Sogamoso — Reserva de Auditorios</a>
            <img src="/images/logoUptc.png" alt="Logo" style="max-width: 80px; height: auto;">
        </div>
    </div>
</nav>

<main class="container">
    <div id="alerta" class="d-none mb-3"></div>

    <div class="row g-4 justify-content-center">

        <!-- Registro -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-header card-header-uptc">Crear cuenta</div>
                <div class="card-body">
                    <form id="form-register">
                        <div class="mb-2">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" id="reg-nombre" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" id="reg-email" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <input type="password" class="form-control" id="reg-password" minlength="6" required>
                        </div>
                        <button type="submit" class="btn btn-uptc w-100">Registrarse</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Login -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-header card-header-dark">Iniciar sesión</div>
                <div class="card-body">
                    <form id="form-login">
                        <div class="mb-2">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" id="log-email" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <input type="password" class="form-control" id="log-password" required>
                        </div>
                        <button type="submit" class="btn btn-dark-uptc w-100">Ingresar</button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</main>

<footer class="navbar-uptc text-light py-3 mt-5">
    <div class="container text-center">
        <span><strong>@Diego Combariza</strong> y <strong>@Daniel Rodriguez - Parcial1 Electiva2</strong></span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/auth.js"></script>
</body>
</html>
