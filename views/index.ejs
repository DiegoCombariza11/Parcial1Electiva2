<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --uptc-gold: #F5A800;
            --uptc-dark: #1a1a1a;
        }
        body { background-color: #f9f5e8; }
        .navbar-uptc { background-color: var(--uptc-dark); }
        .card-header-uptc {
            background-color: var(--uptc-gold);
            color: var(--uptc-dark);
            font-weight: 600;
        }
        .card-header-dark {
            background-color: var(--uptc-dark);
            color: var(--uptc-gold);
            font-weight: 600;
        }
        .btn-uptc {
            background-color: var(--uptc-gold);
            color: var(--uptc-dark);
            font-weight: 600;
            border: none;
        }
        .btn-uptc:hover { background-color: #d4900a; color: #fff; }
        .btn-dark-uptc {
            background-color: var(--uptc-dark);
            color: var(--uptc-gold);
            border: none;
        }
        .btn-dark-uptc:hover { background-color: #333; color: var(--uptc-gold); }
        .badge-uptc { background-color: var(--uptc-dark); color: var(--uptc-gold); }
        .table thead { background-color: var(--uptc-dark); color: var(--uptc-gold); }
        .navbar-brand { color: var(--uptc-gold) !important; }
    </style>
</head>
<body>

<nav class="navbar navbar-uptc mb-4">
    <div class="container">
        <span class="navbar-brand fw-bold">UPTC Sogamoso — Reserva de Auditorios</span>
    </div>
</nav>

<div class="container">

    <div id="alerta" class="d-none mb-3"></div>

    <div class="row g-4">

        <!-- Columna izquierda: Crear recurso + Lista de recursos -->
        <div class="col-md-6">

            <div class="card mb-4">
                <div class="card-header card-header-uptc">Registrar nuevo recurso</div>
                <div class="card-body">
                    <form id="form-recurso">
                        <div class="mb-2">
                            <label class="form-label">ID (número)</label>
                            <input type="number" class="form-control" id="r-id" min="1" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" id="r-nombre" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Capacidad (personas)</label>
                            <input type="number" class="form-control" id="r-capacidad" min="1" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Ubicación</label>
                            <input type="text" class="form-control" id="r-ubicacion" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Descripción</label>
                            <textarea class="form-control" id="r-descripcion" rows="2"></textarea>
                        </div>
                        <button type="submit" class="btn btn-uptc w-100">Crear recurso</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header card-header-dark d-flex justify-content-between align-items-center">
                    <span>Recursos disponibles</span>
                    <button class="btn btn-sm btn-uptc" onclick="cargarRecursos()">Actualizar</button>
                </div>
                <div class="card-body p-0">
                    <div id="lista-recursos">
                        <p class="text-muted p-3 mb-0">Cargando recursos...</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna derecha: Detalle por ID + Hacer reserva -->
        <div class="col-md-6">

            <div class="card mb-4">
                <div class="card-header card-header-uptc">Consultar recurso por ID</div>
                <div class="card-body">
                    <div class="input-group">
                        <input type="number" class="form-control" id="buscar-id" placeholder="Ej: 1, 2, 3...">
                        <button class="btn btn-dark-uptc" onclick="buscarPorId()">Buscar</button>
                    </div>
                    <div id="detalle-recurso" class="mt-3"></div>
                </div>
            </div>

            <div class="card">
                <div class="card-header card-header-uptc">Hacer una reserva</div>
                <div class="card-body">
                    <form id="form-reserva">
                        <div class="mb-2">
                            <label class="form-label">Recurso (auditorio)</label>
                            <select class="form-select" id="res-recurso" required>
                                <option value="">Seleccione un recurso...</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Nombre del solicitante</label>
                            <input type="text" class="form-control" id="res-solicitante" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" id="res-fecha" required>
                        </div>
                        <div class="row">
                            <div class="col mb-2">
                                <label class="form-label">Hora inicio</label>
                                <input type="time" class="form-control" id="res-inicio" required>
                            </div>
                            <div class="col mb-2">
                                <label class="form-label">Hora fin</label>
                                <input type="time" class="form-control" id="res-fin" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-uptc w-100 fw-bold">Reservar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de reservas -->
    <div class="card mt-4 mb-5">
        <div class="card-header card-header-dark d-flex justify-content-between align-items-center">
            <span>Reservas registradas</span>
            <button class="btn btn-sm btn-uptc" onclick="cargarReservas()">Actualizar</button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Recurso</th>
                            <th>Solicitante</th>
                            <th>Fecha</th>
                            <th>Hora inicio</th>
                            <th>Hora fin</th>
                        </tr>
                    </thead>
                    <tbody id="tabla-reservas">
                        <tr><td colspan="5" class="text-center text-muted">Cargando reservas...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
